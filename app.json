{
  "expo": {
    "name": "app-farmacia",
    "slug": "app-farmacia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-farmacia.png",
    "scheme": "appfarmacia",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo-farmacia.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo-farmacia.png",
        "backgroundImage": "",
        "monochromeImage": ""
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/logo-farmacia.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
